PORT=3000

# Configuración de Firebase — completar con las credenciales de TU propio
# proyecto de Firebase (Firebase Console > Configuración del proyecto > SDK de Firebase)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Autenticación (Req #7)
# Clave secreta para firmar/verificar los JWT. Puede ser cualquier string largo
# y random (ej: generado con `require('crypto').randomBytes(32).toString('hex')`)
JWT_SECRET=

# Usuario admin único (no hay colección de usuarios en Firestore para este TP)
ADMIN_USER=
ADMIN_PASS=
